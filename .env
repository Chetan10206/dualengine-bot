# ─────────────────────────────────────────────────────────────────────────
#  Fyers FVG Bot  —  Environment Variables
#
#  HOW TO USE
#  ──────────────────────────────────────────────────────────────────────
#  1. Copy:  cp .env.example .env
#  2. Fill in your Fyers credentials below
#  3. NEVER commit .env to git
#
#  GET FYERS API KEYS
#  ──────────────────────────────────────────────────────────────────────
#  1. Go to  https://myapi.fyers.in/dashboard
#  2. Click  "Create App"
#  3. Set Redirect URI to:
#     https://trade.fyers.in/api-login/redirect-uri/index.html
#  4. Copy Client ID and Secret Key below
#  5. Run:  python main.py login   (once per day to get access token)
# ─────────────────────────────────────────────────────────────────────────

# Your Fyers App Client ID  (format: APPID-100)
FYERS_CLIENT_ID=your_client_id_here

# Your Fyers App Secret Key
FYERS_SECRET_KEY=your_secret_key_here

# Redirect URI  (must match exactly what you set in Fyers dashboard)
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html

# Access Token  (optional — auto-saved by `python main.py login`)
# If blank, the bot will use the saved token from .fyers_token file
FYERS_ACCESS_TOKEN=
